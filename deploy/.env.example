# Host ports
GATEWAY_PORT=8000
PYTHON_VNC_PORT=6080

# Build options
PREFETCH_CAMOUFOX=1

# Shared database path inside containers
APP_DB_URL=sqlite:////app/data/account_manager.db
AAR_DATABASE_URL=sqlite:////app/data/account_manager.db

# Python app
APP_CORS_ALLOW_ORIGINS=*

# Go control plane
AAR_SERVER_PUBLIC_BASE_URL=http://127.0.0.1:8000
AAR_SERVER_CALLBACK_BASE_URL=http://go-control-plane:8080
AAR_WORKER_BASE_URL=http://python-worker:8000
AAR_INTERNAL_CALLBACK_TOKEN=
